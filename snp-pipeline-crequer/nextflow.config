/*
 * Pipeline configuration file
 */

// Global default params
params {
    // Input/output options
    reads = null
    reference = null
    outdir = './results'
    
    // Bowtie2 index
    bowtie2_index = null
    
    // Trimmomatic parameters
    leading = 3
    trailing = 3
    minlen = 36
    slidingwindow = "4:25"
    adapters = null
    
    // Bowtie2 parameters
    max_fragment_length = 1000
    bowtie2_preset = "very-sensitive-local"
    
    // Filtering parameters
    min_mapping_quality = 10
    min_depth = 10
    
    // GATK filtering parameters
    filter_qual = 30
    filter_dp = 10
    filter_qd = 2.0
    filter_fs = 60.0
    filter_mq = 40.0
    filter_sor = 3.0
    filter_mqranksum = -12.5
    filter_readposranksum = -8.0
    
    // NGSadmix parameters
    run_ngsadmix = false
    min_k = 2
    max_k = 6
    ngsadmix_runs = 100
    min_informative_individuals = 4
    
    // Resource options
    max_memory = 128.GB
    max_cpus = 16
    max_time = 240.h
}

// Process configuration
process {
    // Default resources
    cpus = 2
    memory = 4.GB
    time = 2.h
    
    errorStrategy = 'retry'
    maxRetries = 2
    
    // Process-specific resources
    withName: 'TRIMMOMATIC' {
        cpus = 4
        memory = 8.GB
        time = 4.h
        container = 'quay.io/biocontainers/trimmomatic:0.39--hdfd78af_2'
    }
    
    withName: 'BOWTIE2_ALIGN' {
        cpus = 8
        memory = 16.GB
        time = 8.h
        container = 'quay.io/biocontainers/mulled-v2-ac74a7f02cebcfcc07d8e8d1d750af9c83b4d45a:1744f68fe955578c63054b55309e05b41c37a80d-0'
    }
    
    withName: 'SAMTOOLS_.*' {
        cpus = 4
        memory = 8.GB
        time = 4.h
        container = 'quay.io/biocontainers/samtools:1.17--h00cdaf9_0'
    }
    
    withName: 'PREPARE_REFERENCE' {
        cpus = 2
        memory = 8.GB
        time = 2.h
        container = 'broadinstitute/gatk:4.4.0.0'
    }
    
    withName: 'GATK_.*' {
        cpus = 4
        memory = 16.GB
        time = 12.h
        container = 'broadinstitute/gatk:4.4.0.0'
    }
    
    withName: 'GATK_HAPLOTYPECALLER' {
        cpus = 2
        memory = 8.GB
        time = 24.h
    }
    
    withName: 'GATK_COMBINE_GVCFS' {
        cpus = 4
        memory = 32.GB
        time = 12.h
    }
    
    withName: 'GATK_GENOTYPE_GVCFS' {
        cpus = 4
        memory = 32.GB
        time = 24.h
    }
    
    withName: 'ANGSD_.*' {
        cpus = 8
        memory = 16.GB
        time = 12.h
        container = 'quay.io/biocontainers/angsd:0.940--h6bb024c_1'
    }
    
    withName: 'NGSADMIX' {
        cpus = 2
        memory = 8.GB
        time = 6.h
        container = 'quay.io/biocontainers/angsd:0.940--h6bb024c_1'
    }
    
    withName: 'VCF_TO_NEXUS' {
        cpus = 1
        memory = 4.GB
        time = 2.h
        container = 'quay.io/biocontainers/python:3.9'
    }
    
    withName: 'SPLITSTREE' {
        cpus = 2
        memory = 8.GB
        time = 4.h
        container = 'quay.io/biocontainers/splitstree:4.16.2--h7ab15ed_0'
    }
    
    withName: 'VCF_TO_MATRIX' {
        cpus = 1
        memory = 4.GB
        time = 2.h
        container = 'quay.io/biocontainers/python:3.9'
    }
    
    withName: 'ADE4_PCA' {
        cpus = 2
        memory = 8.GB
        time = 4.h
        container = 'quay.io/biocontainers/r-ade4:1.7_22--r43hf939315_1'
    }
}

// Executor configuration
executor {
    name = 'local'
    cpus = 16
    memory = 128.GB
}

// Docker/Singularity configuration
docker {
    enabled = false
    runOptions = '-u $(id -u):$(id -g)'
}

singularity {
    enabled = false
    autoMounts = true
}

// Conda configuration
conda {
    enabled = false
}

// Report configuration
report {
    enabled = true
    file = "${params.outdir}/reports/execution_report.html"
}

timeline {
    enabled = true
    file = "${params.outdir}/reports/execution_timeline.html"
}

trace {
    enabled = true
    file = "${params.outdir}/reports/execution_trace.txt"
}

dag {
    enabled = true
    file = "${params.outdir}/reports/pipeline_dag.html"
}

// Manifest
manifest {
    name = 'P. roqueforti Variant Calling Pipeline'
    author = 'Converted from methods section'
    description = 'Variant calling pipeline for P. roqueforti using Trimmomatic, Bowtie2, SAMtools, and GATK'
    mainScript = 'main.nf'
    nextflowVersion = '>=21.10.0'
    version = '1.0.0'
}

// Profiles
profiles {
    
    standard {
        process.executor = 'local'
    }
    
    docker {
        docker.enabled = true
        singularity.enabled = false
        conda.enabled = false
    }
    
    singularity {
        singularity.enabled = true
        docker.enabled = false
        conda.enabled = false
    }
    
    conda {
        conda.enabled = true
        docker.enabled = false
        singularity.enabled = false
        process {
            withName: 'TRIMMOMATIC' {
                conda = 'bioconda::trimmomatic=0.39'
            }
            withName: 'BOWTIE2_ALIGN' {
                conda = 'bioconda::bowtie2=2.5.1 bioconda::samtools=1.17'
            }
            withName: 'SAMTOOLS_.*' {
                conda = 'bioconda::samtools=1.17'
            }
            withName: 'PREPARE_REFERENCE|GATK_.*' {
                conda = 'bioconda::gatk4=4.4.0.0'
            }
            withName: 'ANGSD_.*|NGSADMIX' {
                conda = 'bioconda::angsd=0.940'
            }
            withName: 'VCF_TO_NEXUS|VCF_TO_MATRIX' {
                conda = 'conda-forge::python=3.9'
            }
            withName: 'SPLITSTREE' {
                conda = 'bioconda::splitstree=4.16.2'
            }
            withName: 'ADE4_PCA' {
                conda = 'conda-forge::r-base=4.3 bioconda::r-ade4=1.7'
            }
        }
    }
    
    slurm {
        process {
            executor = 'slurm'
            queue = 'batch'
            clusterOptions = '--account=your_account'
        }
        executor {
            queueSize = 50
            submitRateLimit = '10 sec'
        }
    }
    
    awsbatch {
        process {
            executor = 'awsbatch'
            queue = 'your-queue-name'
        }
        aws {
            region = 'us-east-1'
            batch {
                cliPath = '/home/ec2-user/miniconda/bin/aws'
            }
        }
    }
    
    test {
        params {
            reads = "${baseDir}/test_data/*_R{1,2}.fastq.gz"
            reference = "${baseDir}/test_data/reference.fasta"
            bowtie2_index = "${baseDir}/test_data/reference"
            outdir = "./test_results"
            max_memory = 8.GB
            max_cpus = 4
        }
    }
}

// Cleanup options
cleanup = false
