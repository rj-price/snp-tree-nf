/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Base Process Configuration
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
*/

process {
    // Default publishing options
    publishDir = [
        path: { "${params.outdir}/${task.process.tokenize(':')[-1].toLowerCase()}" },
        mode: params.publish_dir_mode,
        saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
    ]

    // Default resource requirements
    cpus   = { check_max( 1 * task.attempt, 'cpus' ) }
    memory = { check_max( 2.GB * task.attempt, 'memory' ) }
    time   = { check_max( 4.h * task.attempt, 'time' ) }

    // Error handling
    errorStrategy = { task.exitStatus in [143,137,104,134,139] ? 'retry' : 'finish' }
    maxRetries    = 3
    maxErrors     = '-1'

    // Process-specific resource requirements
    withLabel: 'process_single' {
        cpus   = { check_max( 1 * task.attempt, 'cpus' ) }
        memory = { check_max( 2.GB * task.attempt, 'memory' ) }
        time   = { check_max( 4.h * task.attempt, 'time' ) }
    }
    
    withLabel: 'process_low' {
        cpus   = { check_max( 2 * task.attempt, 'cpus' ) }
        memory = { check_max( 2.GB * task.attempt, 'memory' ) }
        time   = { check_max( 4.h * task.attempt, 'time' ) }
    }
    
    withLabel: 'process_medium' {
        cpus   = { check_max( 4 * task.attempt, 'cpus' ) }
        memory = { check_max( 8.GB * task.attempt, 'memory' ) }
        time   = { check_max( 8.h * task.attempt, 'time' ) }

    }
    
    withLabel: 'process_high' {
        cpus   = { check_max( 8 * task.attempt, 'cpus' ) }
        memory = { check_max( 16.GB * task.attempt, 'memory' ) }
        time   = { check_max( 16.h * task.attempt, 'time' ) }

    }

    // Process-specific configurations
    withName: 'SAMPLESHEET_CHECK' {
        publishDir = [
            path: { "${params.outdir}/pipeline_info" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }

    withName: 'FASTQC.*' {
        publishDir = [
            path: { "${params.outdir}/fastqc/${meta.id}" },
            mode: params.publish_dir_mode,
            pattern: '*.{html,zip}'
        ]
    }

    withName: 'TRIMMOMATIC' {
        publishDir = [
            path: { "${params.outdir}/trimmomatic/${meta.id}" },
            mode: params.publish_dir_mode,
            pattern: '*.{fastq.gz,log}'
        ]
    }

    withName: 'BWA_INDEX' {
        publishDir = [
            path: { "${params.outdir}/bwa_index" },
            mode: params.publish_dir_mode,
            enabled: false  // Don't publish index files by default
        ]
    }

    withName: 'BWA_MEM' {
        publishDir = [
            path: { "${params.outdir}/bwa_mem/${meta.id}" },
            mode: params.publish_dir_mode,
            enabled: false  // Don't publish SAM files by default
        ]
    }

    withName: 'SAMTOOLS_.*' {
        publishDir = [
            path: { "${params.outdir}/samtools/${meta.id}" },
            mode: params.publish_dir_mode,
            pattern: '*.{bam,bai,stats}'
        ]
    }

    withName: 'SAMTOOLS_FAIDX' {
        publishDir = [
            path: { "${params.outdir}/samtools_faidx" },
            mode: params.publish_dir_mode,
            enabled: false  // Don't publish index by default
        ]
    }

    withName: 'BCFTOOLS_MPILEUP' {
        publishDir = [
            path: { "${params.outdir}/variants/${meta.id}" },
            mode: params.publish_dir_mode,
            pattern: '*.vcf.gz'
        ]
    }

    withName: 'BCFTOOLS_FILTER' {
        publishDir = [
            path: { "${params.outdir}/variants/${meta.id}" },
            mode: params.publish_dir_mode,
            pattern: '*.filtered.vcf.gz'
        ]
    }

    withName: 'VCF_TO_PHYLIP' {
        publishDir = [
            path: { "${params.outdir}/phylogenetics" },
            mode: params.publish_dir_mode,
            pattern: '*.phy'
        ]
    }

    withName: 'RAXML' {
        publishDir = [
            path: { "${params.outdir}/phylogenetics/raxml" },
            mode: params.publish_dir_mode,
            pattern: 'RAxML_*'
        ]
    }

    withName: 'VCF_TO_NEXUS' {
        publishDir = [
            path: { "${params.outdir}/phylogenetics" },
            mode: params.publish_dir_mode,
            pattern: '*.nex'
        ]
    }

    withName: 'MULTIQC' {
        publishDir = [
            path: { "${params.outdir}/multiqc" },
            mode: params.publish_dir_mode,
            pattern: 'multiqc_*'
        ]
    }
}
